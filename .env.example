# beeromat environment variables — deployment-scoped only.
#
# Per the constitution (Principle II, v1.1.1), all CLUB-scoped configuration
# (currency, IBAN, locale default, low-stock thresholds, beer types, member
# roles, etc.) is administered via the in-app admin UI and lives in the
# database. This file holds ONLY deployment-scoped concerns: connection
# strings, third-party API keys, and bootstrap seed values.
#
# Copy to .env.local for local development; configure via Vercel's environment
# variables UI for production.

# ─────────────────────────────────────────────────────────────────────────
# Database (Neon Postgres)
# ─────────────────────────────────────────────────────────────────────────
# Connection string from your Neon project dashboard.
DATABASE_URL="postgres://user:pass@xxx.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────────────────────────────────
# Better Auth
# ─────────────────────────────────────────────────────────────────────────
# 32+ random bytes, base64-encoded. Generate locally with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=""
# Canonical app URL (used for magic-link callback URLs).
BETTER_AUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
# Sender identity. Use Resend's onboarding@resend.dev sandbox for dev, or
# a verified custom domain for production.
EMAIL_FROM="beeromat <onboarding@resend.dev>"

# ─────────────────────────────────────────────────────────────────────────
# Bot mitigation (Cloudflare Turnstile)
# ─────────────────────────────────────────────────────────────────────────
# Site key is public (prefixed NEXT_PUBLIC_ so it's exposed to the browser).
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAA..."
# Secret key is server-only.
TURNSTILE_SECRET_KEY="0x4AAA..."

# ─────────────────────────────────────────────────────────────────────────
# Rate limiting (Upstash Redis)
# ─────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL="https://...upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# ─────────────────────────────────────────────────────────────────────────
# Seed (used by `pnpm db:seed` to bootstrap the v1 single-club deployment)
# ─────────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL="you@example.com"
SEED_ADMIN_NAME="Your Name"
SEED_CLUB_NAME="TK Slávia Praha"
SEED_CLUB_CURRENCY="CZK"
SEED_CLUB_LOCALE="cs-CZ"

# ─────────────────────────────────────────────────────────────────────────
# Optional flags
# ─────────────────────────────────────────────────────────────────────────
# Skip env validation at import time. Useful for `next build` in CI when
# real secrets are injected later. NEVER set this at runtime in production.
# SKIP_ENV_VALIDATION="1"
