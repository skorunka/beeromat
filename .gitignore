# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code agent folder — may contain auth tokens / credentials.
# Ignore its contents by default, then un-ignore .claude/skills/ so the
# speckit-* slash commands installed by `specify init --here --ai claude`
# survive `git clean` and fresh clones. (Git only honours negations when
# the parent is matched with /* rather than /.)
.claude/*
!.claude/skills/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/blob-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.test

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# playwright
playwright/.auth/
playwright-report/
test-results/
