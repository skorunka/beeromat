# Test environment variables — fake but valid values for E2E smoke testing.
#
# These values pass lib/env.ts Zod validation and let Better Auth /
# Resend / Upstash modules initialize without throwing. They DO NOT
# point at any real service: smoke tests must not exercise the network
# or any persistent state.
#
# Later commits in the E2E chain replace specific entries with real
# isolated test instances (Neon branch, Resend intercept, etc.).

DATABASE_URL=postgresql://test_user:test_pass@localhost.test:5432/beeromat_test?sslmode=require
BETTER_AUTH_SECRET=YHvUYR9F1tT6q3WdLkSjE7nMxBcZA0PoIuJgKfHeDsRtNvCxBnAlSkDjFhGgYy7w
BETTER_AUTH_URL=http://localhost:3100
RESEND_API_KEY=re_test_smoke_only_do_not_use
EMAIL_FROM=beeromat-test@example.com
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
UPSTASH_REDIS_REST_URL=http://localhost.test:9999
UPSTASH_REDIS_REST_TOKEN=test_token_unused_in_smoke
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_NAME=Test Admin
SEED_CLUB_NAME=Test Club
SEED_CLUB_CURRENCY=CZK
SEED_CLUB_LOCALE=cs-CZ
NODE_ENV=production
