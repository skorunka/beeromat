# Test environment — fake-but-valid values for the E2E suite.
#
# Every value here is non-production: hosts resolve to loopback or
# nowhere, API keys are obvious placeholders, the Turnstile keys are
# Cloudflare's documented always-pass test pair. This file is
# committed to git on purpose (see .gitignore's `!.env.test`).
#
# It is loaded ONLY by playwright.config.ts for the test webServer and
# by the E2E fixtures. Production deploys never read it (Vercel injects
# env via its dashboard).

# --- App database access (production code path) ---------------------
# The app-under-test reaches Postgres through the Neon HTTP proxy,
# exactly as production reaches Neon Cloud. Only the endpoint differs.
# DATABASE_URL supplies credentials + db name; with the fetchEndpoint
# override the driver POSTs queries to the proxy rather than resolving
# this host directly.
DATABASE_URL=postgresql://beeromat:beeromat@localhost/beeromat_test
NEON_FETCH_ENDPOINT=http://localhost:14445/sql

# --- Test fixture database access (test infrastructure) -------------
# The E2E fixtures (migrate / truncate / seed) connect DIRECTLY to the
# Docker Postgres, bypassing the proxy — the proxy's ~450ms/query
# latency would make a 70-statement migration take ~35s. Direct
# connection on the non-default host port 5433.
TEST_DATABASE_DIRECT_URL=postgresql://beeromat:beeromat@localhost:5433/beeromat_test

# --- Auth / email / bot-mitigation (all fake) -----------------------
# Obvious placeholder — NOT a real secret. Long enough to satisfy the
# 32-char minimum in lib/env.ts.
BETTER_AUTH_SECRET=test-only-fake-secret-do-not-use-in-production-padding-000
BETTER_AUTH_URL=http://localhost:3100
RESEND_API_KEY=re_test_fake_key_never_sends_real_email
EMAIL_FROM=beeromat-test@example.com
# Cloudflare's documented test keys (always-pass site key + secret).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
UPSTASH_REDIS_REST_URL=http://localhost.test:9999
UPSTASH_REDIS_REST_TOKEN=test-token-unused-in-e2e

# --- Seed values ----------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.test
SEED_ADMIN_NAME=Test Admin
SEED_CLUB_NAME=Test Club
SEED_CLUB_CURRENCY=CZK
SEED_CLUB_LOCALE=cs-CZ

# NOTE on NODE_ENV: deliberately NOT set here. The E2E suite runs the
# production build, and `next start` sets NODE_ENV=production itself —
# duplicating it here only made this file look production-shaped.
#
# Why this file is safe to commit and cannot leak into production:
#   - It is loaded ONLY by playwright.config.ts (for the test
#     webServer) and the E2E fixtures. Vercel injects production env
#     from its own dashboard and never sources repo .env files.
#   - All values are fake (loopback hosts, placeholder keys).
#   - Every destructive DB operation goes through the fixture's
#     assertLoopback guard, which refuses any non-loopback host —
#     so even a misdirected config cannot wipe a real database.
